# JobAlert by KB — Variables d'environnement (copier en .env, ne pas committer .env)
# ═══════════════════════════════════════════════════════════════

# ─── API (main.py / FastAPI) ───
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_JWT_SECRET=xxx
SUPABASE_SERVICE_KEY=xxx
OPENAI_API_KEY=sk-xxx
CLIENT_ID=xxx
CLIENT_SECRET=xxx
CORS_ORIGINS=https://jobalertkb.fr,https://www.jobalertkb.fr
LIMIT_CANDIDATURES_FREE=3

# ─── France Travail (1_france_travail.py / orchestrateur) ───
# CLIENT_ID et CLIENT_SECRET déjà ci‑dessus

# ─── Notifications (4_notifications.py / orchestrateur) ───
