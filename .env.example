# === API France Travail ===
LBA_API_KEY=your_france_travail_api_key_here

# === OpenAI ===
OPENAI_API_KEY=sk-...

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
# Clé service role — nécessaire pour l'orchestrateur (bypass RLS)
# À trouver dans : Supabase > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# === SMTP (Brevo) ===
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_email
SMTP_PASS=your_brevo_smtp_key
SMTP_FROM=noreply@jobalert.app

# === CORS ===
# URL(s) autorisées, séparées par une virgule
ALLOWED_ORIGINS=https://your-frontend-domain.com
