SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_EXPEDITEUR=notifications@jobalertkb.fr
NOM_EXPEDITEUR=JobAlert IA

# ─── Orchestrateur (5_orchestrateur.py) ───
